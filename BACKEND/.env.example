# Secret usado por TODOS los servicios para firmar/validar JWT.
# Debe ser el mismo en auth/users/products/orders/payments.
# Generar con: openssl rand -base64 48
JWT_SECRET=replace_me_with_a_long_random_value

# Secret para promover un usuario a admin desde auth-service y users-service.
# Generar con: openssl rand -base64 48
ADMIN_PROMOTE_SECRET=replace_me_with_a_long_random_value
