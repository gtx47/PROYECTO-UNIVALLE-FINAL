# Secret usado por TODOS los servicios para firmar/validar JWT.
# Debe ser el mismo en auth/users/products/orders/payments.
# Generar con: openssl rand -base64 48
JWT_SECRET=replace_me_with_a_long_random_value

# Secret para promover un usuario a admin desde auth-service y users-service.
# Generar con: openssl rand -base64 48
ADMIN_PROMOTE_SECRET=replace_me_with_a_long_random_value

# MongoDB Atlas — solicita las credenciales al dueño del proyecto.
# Cada variable apunta a una base de datos distinta dentro del mismo cluster.
MONGO_URI_AUTH=mongodb+srv://<usuario>:<password>@cluster0.no82gn4.mongodb.net/auth?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI_USERS=mongodb+srv://<usuario>:<password>@cluster0.no82gn4.mongodb.net/users?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI_PRODUCTS=mongodb+srv://<usuario>:<password>@cluster0.no82gn4.mongodb.net/products?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI_ORDERS=mongodb+srv://<usuario>:<password>@cluster0.no82gn4.mongodb.net/orders?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI_PAYMENTS=mongodb+srv://<usuario>:<password>@cluster0.no82gn4.mongodb.net/payments?retryWrites=true&w=majority&appName=Cluster0
